{
  "name": "@legonode/cron",
  "version": "0.0.2",
  "description": "Cron schedules, loader, and runner for Legonode apps (app/cron/*.cron.ts)",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "peerDependencies": {
    "legonode": ">=0.0.5"
  },
  "devDependencies": {
    "legonode": "^0.0.5"
  }
}
