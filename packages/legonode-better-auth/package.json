{
  "name": "@legonode/better-auth",
  "version": "0.0.1",
  "description": "Better Auth integration for Legonode",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "default": "./dist/setup.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "better-auth": "^1.0.0",
    "legonode": ">=0.0.9"
  },
  "devDependencies": {
    "better-auth": "^1.0.0",
    "legonode": "^0.0.9",
    "typescript": "^5.9.0"
  }
}

